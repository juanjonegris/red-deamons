---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CartItem from "../components/cart/CartItem.astro";
import CartSummary from "../components/cart/CartSummary.astro";
import { getLocalCart, getLocalCartItemCount } from "../lib/cart";

// Get local cart data for guest users
const localCart = getLocalCart();
const itemCount = getLocalCartItemCount();

// Calculate cart totals
const subtotal = localCart.items.reduce((total, item) => {
    // For now, we'll need to fetch product data
    // This will be improved when we have proper cart state management
    return total; // Placeholder
}, 0);
---

<Layout title="Red Demons | Carrito">
    <div class="flex flex-col min-h-screen bg-black">
        <Header />

        <main class="flex-grow flex flex-col items-center justify-center p-4 lg:p-8">
            <div class="max-w-4xl w-full">
                <!-- Page Header -->
                <div class="mb-8">
                    <h1 class="text-4xl md:text-5xl font-bold uppercase tracking-wider text-white mb-4">
                        Mi Carrito
                    </h1>
                    <nav class="flex items-center space-x-2 text-sm">
                        <a href="/" class="text-zinc-400 hover:text-white transition-colors">Inicio</a>
                        <span class="text-zinc-600">/</span>
                        <a href="/tienda" class="text-zinc-400 hover:text-white transition-colors">Tienda</a>
                        <span class="text-zinc-600">/</span>
                        <span class="text-white">Carrito</span>
                    </nav>
                </div>

                {localCart.items.length > 0 ? (
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                        <!-- Cart Items -->
                        <div class="lg:col-span-2">
                            <div class="bg-zinc-900 rounded-lg border border-zinc-800">
                                {localCart.items.map((item) => (
                                    <div class="p-4 border-b border-zinc-800 last:border-b-0">
                                        <div class="flex gap-4">
                                            <!-- Product Image Placeholder -->
                                            <div class="w-20 h-20 bg-zinc-800 rounded-lg overflow-hidden flex-shrink-0">
                                                <div class="w-full h-full flex items-center justify-center text-zinc-600">
                                                    IMG
                                                </div>
                                            </div>

                                            <!-- Product Details -->
                                            <div class="flex-grow">
                                                <h3 class="text-white font-medium mb-1">Producto #{item.product_variant_id}</h3>
                                                <p class="text-zinc-400 text-sm mb-2">Variante</p>
                                                <p class="text-red-500 font-semibold">$0.00</p>
                                            </div>

                                            <!-- Quantity Controls -->
                                            <div class="flex flex-col items-end gap-2">
                                                <div class="flex items-center gap-2">
                                                    <button
                                                        class="w-8 h-8 rounded bg-zinc-800 hover:bg-zinc-700 text-white flex items-center justify-center transition-colors"
                                                        onclick="updateCartItem({item.product_variant_id}, {item.quantity - 1})"
                                                    >
                                                        -
                                                    </button>
                                                    <span class="text-white font-medium w-8 text-center">{item.quantity}</span>
                                                    <button
                                                        class="w-8 h-8 rounded bg-zinc-800 hover:bg-zinc-700 text-white flex items-center justify-center transition-colors"
                                                        onclick="updateCartItem({item.product_variant_id}, {item.quantity + 1})"
                                                    >
                                                        +
                                                    </button>
                                                </div>
                                                
                                                <div class="text-right">
                                                    <p class="text-white font-semibold">$0.00</p>
                                                    <button
                                                        class="text-zinc-400 hover:text-red-500 text-xs transition-colors"
                                                        onclick="removeFromCart({item.product_variant_id})"
                                                    >
                                                        Eliminar
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <!-- Cart Summary -->
                        <div class="lg:col-span-1">
                            <div class="bg-zinc-900 rounded-lg border border-zinc-800 p-6 sticky top-8">
                                <CartSummary subtotal={subtotal} />
                            </div>
                        </div>
                    </div>
                ) : (
                    <!-- Empty Cart -->
                    <div class="text-center py-16">
                        <svg
                            class="w-24 h-24 text-zinc-600 mx-auto mb-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"
                            ></path>
                        </svg>
                        <h2 class="text-2xl font-bold text-white mb-4">Tu carrito está vacío</h2>
                        <p class="text-zinc-400 mb-8 max-w-md mx-auto">
                            Parece que aún no has agregado productos a tu carrito. ¡Explora nuestra tienda y encuentra algo increíble!
                        </p>
                        <a
                            href="/tienda"
                            class="inline-block bg-red-600 hover:bg-red-700 text-white font-bold uppercase tracking-wider py-3 px-8 rounded-lg transition-all hover:shadow-[0_0_20px_rgba(220,38,38,0.5)]"
                        >
                            Ir a la Tienda
                        </a>
                    </div>
                )}
            </div>
        </main>

        <Footer />
    </div>
</Layout>

<script>
    // Cart management functions
    async function updateCartItem(productVariantId, quantity) {
        try {
            if (quantity <= 0) {
                removeFromCart(productVariantId);
                return;
            }

            // Update local cart
            const response = await fetch('/api/cart/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    productVariantId,
                    quantity
                })
            });

            if (response.ok) {
                // Reload page to show updated cart
                window.location.reload();
            } else {
                console.error('Error updating cart item');
            }
        } catch (error) {
            console.error('Error updating cart item:', error);
        }
    }

    async function removeFromCart(productVariantId) {
        try {
            const response = await fetch('/api/cart/remove', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    productVariantId
                })
            });

            if (response.ok) {
                // Reload page to show updated cart
                window.location.reload();
            } else {
                console.error('Error removing cart item');
            }
        } catch (error) {
            console.error('Error removing cart item:', error);
        }
    }

    // Make functions globally available
    window.updateCartItem = updateCartItem;
    window.removeFromCart = removeFromCart;
</script>
