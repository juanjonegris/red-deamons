---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { supabase } from "../../lib/supabase";
import type { Product, ProductVariant, ProductImage } from "../../lib/types";
import { addToLocalCart, validateStock } from "../../lib/cart";

export async function getStaticPaths() {
    const { data: products } = await supabase
        .from("products")
        .select("slug")
        .eq("is_active", true);

    return (products || []).map((product) => ({
        params: { slug: product.slug },
    }));
}

const { slug } = Astro.params;

const { data: productData, error } = await supabase
    .from("products")
    .select(
        `
    *,
    categories (*),
    product_images (*),
    product_variants (*)
  `,
    )
    .eq("slug", slug)
    .single();

if (error || !productData) {
    return Astro.redirect("/tienda");
}

const product = productData as Product;
const images = (product.product_images || []).sort(
    (a, b) => a.display_order - b.display_order,
);
const primaryImage = images.find((img) => img.is_primary) || images[0];
const variants = (product.product_variants || []) as ProductVariant[];

// Determine stock status
const totalStock = variants.reduce(
    (acc, variant) => acc + variant.stock_quantity,
    0,
);
const isOutOfStock = totalStock === 0;

// Get unique attributes for variant selection (simplified for now to just show list if exists)
// A more complex implementation would require valid combination logic.

// State for selected variant
let selectedVariantId: number | null = variants.length > 0 ? variants[0].id : null;
---

<Layout title={`Red Demons | ${product.title}`}>
    <div class="flex flex-col min-h-screen bg-black">
        <Header />

        <main
            class="flex-grow flex flex-col items-center justify-center p-4 lg:p-8"
        >
            <div
                class="max-w-7xl w-full grid grid-cols-1 lg:grid-cols-2 gap-12 mt-8"
            >
                {/* Image Gallery */}
                <div class="flex flex-col gap-4">
                    <div
                        class="aspect-square w-full rounded-lg overflow-hidden bg-zinc-900 border border-zinc-800 relative"
                    >
                        {
                            /* Main Image - For simplicity in this static version, just showing primary */
                        }
                        {
                            primaryImage ? (
                                <img
                                    src={primaryImage.image_url}
                                    alt={primaryImage.alt_text || product.title}
                                    class="w-full h-full object-cover"
                                />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center text-zinc-600">
                                    No Image
                                </div>
                            )
                        }
                    </div>
                </div>

                {/* Product Details */}
                <div class="flex flex-col gap-6 text-white">
                    <div>
                        {
                            product.categories && (
                                <a
                                    href="/tienda"
                                    class="text-zinc-500 hover:text-red-500 transition-colors text-sm uppercase tracking-wider mb-2 inline-block"
                                >
                                    {product.categories.name}
                                </a>
                            )
                        }
                        <h1
                            class="text-4xl md:text-5xl font-bold uppercase tracking-wide"
                        >
                            {product.title}
                        </h1>
                        <p class="text-2xl text-red-500 font-semibold mt-4">
                            ${Number(product.base_price).toFixed(2)}
                        </p>
                    </div>

                    <div class="prose prose-invert text-zinc-300">
                        <p>{product.description}</p>
                    </div>

                    {/* Stock Status */}
                    <div class="flex items-center gap-2">
                        <div
                            class={`w-3 h-3 rounded-full ${isOutOfStock ? "bg-red-600" : "bg-green-500"}`}
                        >
                        </div>
                        <span
                            class="text-sm font-medium uppercase tracking-wider text-zinc-400"
                        >
                            {isOutOfStock ? "Agotado" : `${totalStock} unidades disponibles`}
                        </span>
                    </div>

                    {/* Variants Section */}
                    {
                        variants.length > 0 && !isOutOfStock && (
                            <div class="flex flex-col gap-3">
                                <span class="text-sm font-medium text-zinc-400">
                                    Variantes Disponibles:
                                </span>
                                <div class="flex flex-wrap gap-2">
                                    {variants.map((variant) => (
                                        <button
                                            disabled={
                                                variant.stock_quantity === 0
                                            }
                                            onclick={`selectVariant(${variant.id})`}
                                            class={`px-4 py-2 rounded border text-sm font-medium transition-colors relative
                                            ${
                                                variant.stock_quantity === 0
                                                    ? "border-zinc-800 text-zinc-600 bg-zinc-900 cursor-not-allowed decoration-line-through"
                                                    : selectedVariantId === variant.id
                                                    ? "border-red-500 bg-red-500/20 text-white"
                                                    : "border-zinc-700 hover:border-red-500 bg-zinc-900/50 text-white"
                                            }
                                        `}
                                        >
                                            <div>
                                                {Object.entries(variant.attributes)
                                                    .map(
                                                        ([key, value]) =>
                                                            `${value}`,
                                                    )
                                                    .join(" / ") || "Standard"}
                                            </div>
                                            {variant.stock_quantity > 0 && (
                                                <div class="text-xs text-zinc-400 mt-1">
                                                    {variant.stock_quantity} unid.
                                                </div>
                                            )}
                                        </button>
                                    ))}
                                </div>
                            </div>
                        )
                    }

                    {/* Add to Cart Button */}
                    <button
                        disabled={isOutOfStock || !selectedVariantId}
                        onclick="addToCart()"
                        class={`mt-8 w-full py-4 px-6 rounded-lg font-bold uppercase tracking-widest transition-all
                            ${
                                isOutOfStock || !selectedVariantId
                                    ? "bg-zinc-800 text-zinc-500 cursor-not-allowed"
                                    : "bg-red-600 hover:bg-red-700 text-white hover:shadow-[0_0_20px_rgba(220,38,38,0.5)]"
                            }
                        `}
                    >
                        {isOutOfStock ? "Sin Stock" : !selectedVariantId ? "Selecciona una variante" : "Agregar al Carrito"}
                    </button>

                    {/* Success Message */}
                    <div id="success-message" class="hidden mt-4 p-4 bg-green-900/50 border border-green-600 rounded-lg">
                        <p class="text-green-400 text-center font-medium">
                            ¡Producto agregado al carrito exitosamente!
                        </p>
                    </div>
                </div>
            </div>
        </main>

        <Footer />
    </div>
</Layout>

<script>
    let selectedVariantId = null;

    // Client-side cart functions
    function getLocalCart() {
        try {
            const cartData = localStorage.getItem('red-demons-cart');
            if (!cartData) {
                return {
                    items: [],
                    created_at: new Date().toISOString(),
                    updated_at: new Date().toISOString()
                };
            }
            return JSON.parse(cartData);
        } catch (error) {
            return {
                items: [],
                created_at: new Date().toISOString(),
                updated_at: new Date().toISOString()
            };
        }
    }

    function saveLocalCart(cart) {
        try {
            cart.updated_at = new Date().toISOString();
            localStorage.setItem('red-demons-cart', JSON.stringify(cart));
        } catch (error) {
            console.error('Error saving local cart:', error);
        }
    }

    function addToLocalCart(productVariantId, quantity = 1) {
        const cart = getLocalCart();
        const existingItem = cart.items.find(item => item.product_variant_id === productVariantId);
        
        if (existingItem) {
            existingItem.quantity += quantity;
        } else {
            cart.items.push({
                id: Math.random().toString(36).substring(2) + Date.now().toString(36),
                product_variant_id: productVariantId,
                quantity,
                added_at: new Date().toISOString()
            });
        }
        
        saveLocalCart(cart);
        return cart;
    }

    function selectVariant(variantId) {
        selectedVariantId = variantId;
        
        // Update button styles
        document.querySelectorAll('[onclick^="selectVariant"]').forEach(btn => {
            btn.classList.remove('border-red-500', 'bg-red-500/20');
            btn.classList.add('border-zinc-700', 'bg-zinc-900/50');
        });
        
        const selectedBtn = document.querySelector(`[onclick="selectVariant(${variantId})"]`);
        if (selectedBtn) {
            selectedBtn.classList.remove('border-zinc-700', 'bg-zinc-900/50');
            selectedBtn.classList.add('border-red-500', 'bg-red-500/20');
        }
    }

    async function addToCart() {
        if (!selectedVariantId) {
            alert('Por favor selecciona una variante');
            return;
        }

        try {
            // Add to local cart directly (client-side)
            const cart = addToLocalCart(selectedVariantId, 1);
            
            // Update cart count and show success message
            updateCartCount();
            
            console.log('Item added to cart:', cart);
        } catch (error) {
            console.error('Error adding to cart:', error);
            alert('Error al agregar al carrito');
        }
    }

    function updateCartCount() {
        // Dispatch custom event to update cart count in header
        window.dispatchEvent(new CustomEvent('cartUpdated'));
        
        // Also update the success message
        const successMsg = document.getElementById('success-message');
        if (successMsg) {
            successMsg.classList.remove('hidden');
            
            // Hide success message after 3 seconds
            setTimeout(() => {
                successMsg.classList.add('hidden');
            }, 3000);
        }
    }

    // Make functions globally available
    window.selectVariant = selectVariant;
    window.addToCart = addToCart;

    // Initialize first variant as selected
    document.addEventListener('DOMContentLoaded', () => {
        const firstVariant = document.querySelector('[onclick^="selectVariant"]');
        if (firstVariant) {
            const variantId = firstVariant.getAttribute('onclick').match(/\d+/)[0];
            selectVariant(parseInt(variantId));
        }
    });
</script>
