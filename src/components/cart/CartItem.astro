---
import type { CartItem, ProductVariant, Product } from '../../lib/types';
import { formatPrice } from '../../lib/cart';

interface Props {
    item: CartItem & {
        product_variant: ProductVariant & {
            product: Product;
        };
    };
    onUpdateQuantity: (productVariantId: number, quantity: number) => void;
    onRemove: (productVariantId: number) => void;
}

const { item, onUpdateQuantity, onRemove } = Astro.props;

const variant = item.product_variant;
const product = variant.product;
const itemTotal = (variant.price || product.base_price) * item.quantity;

// Format variant attributes for display
const variantDisplay = Object.entries(variant.attributes)
    .map(([key, value]) => `${value}`)
    .join(' / ') || 'Standard';
---

<div class="flex gap-4 p-4 border-b border-zinc-800 last:border-b-0">
    {/* Product Image */}
    <div class="w-20 h-20 bg-zinc-800 rounded-lg overflow-hidden flex-shrink-0">
        <img
            src={product.product_images?.[0]?.image_url || '/placeholder-product.jpg'}
            alt={product.title}
            class="w-full h-full object-cover"
        />
    </div>

    {/* Product Details */}
    <div class="flex-grow">
        <h3 class="text-white font-medium text-sm mb-1">{product.title}</h3>
        <p class="text-zinc-400 text-xs mb-2">{variantDisplay}</p>
        <p class="text-red-500 font-semibold">{formatPrice(variant.price || product.base_price)}</p>
    </div>

    {/* Quantity Controls */}
    <div class="flex flex-col items-end gap-2">
        <div class="flex items-center gap-2">
            <button
                onclick={`updateCartItem(${variant.id}, ${item.quantity - 1})`}
                class="w-8 h-8 rounded bg-zinc-800 hover:bg-zinc-700 text-white flex items-center justify-center transition-colors"
                aria-label="Reducir cantidad"
            >
                -
            </button>
            <span class="text-white font-medium w-8 text-center">{item.quantity}</span>
            <button
                onclick={`updateCartItem(${variant.id}, ${item.quantity + 1})`}
                class="w-8 h-8 rounded bg-zinc-800 hover:bg-zinc-700 text-white flex items-center justify-center transition-colors"
                aria-label="Aumentar cantidad"
            >
                +
            </button>
        </div>
        
        <div class="text-right">
            <p class="text-white font-semibold">{formatPrice(itemTotal)}</p>
            <button
                onclick={`removeFromCart(${variant.id})`}
                class="text-zinc-400 hover:text-red-500 text-xs transition-colors"
            >
                Eliminar
            </button>
        </div>
    </div>
</div>

<script>
    function updateCartItem(productVariantId, quantity) {
        if (quantity <= 0) {
            removeFromCart(productVariantId);
        } else {
            // This will be handled by the parent component
            window.updateCartItem?.(productVariantId, quantity);
        }
    }

    function removeFromCart(productVariantId) {
        // This will be handled by the parent component
        window.removeFromCart?.(productVariantId);
    }
</script>
