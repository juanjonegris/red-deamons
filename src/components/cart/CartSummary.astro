---
import { formatPrice } from '../../lib/cart';

interface Props {
    subtotal: number;
    shipping?: number;
    total?: number;
}

const { subtotal, shipping = 0, total = subtotal + shipping } = Astro.props;
---

<div class="border-t border-zinc-800 pt-4 mt-4">
    <div class="space-y-2">
        <div class="flex justify-between text-sm">
            <span class="text-zinc-400">Subtotal</span>
            <span class="text-white">{formatPrice(subtotal)}</span>
        </div>
        
        {shipping > 0 && (
            <div class="flex justify-between text-sm">
                <span class="text-zinc-400">Envío</span>
                <span class="text-white">{formatPrice(shipping)}</span>
            </div>
        )}
        
        <div class="flex justify-between text-lg font-semibold pt-2 border-t border-zinc-800">
            <span class="text-white">Total</span>
            <span class="text-red-500">{formatPrice(total)}</span>
        </div>
    </div>
    
    <button class="w-full mt-6 bg-red-600 hover:bg-red-700 text-white font-bold uppercase tracking-wider py-3 px-6 rounded-lg transition-all hover:shadow-[0_0_20px_rgba(220,38,38,0.5)]">
        Finalizar Compra
    </button>
</div>
