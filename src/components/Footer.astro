---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black text-white py-12 border-t-8 border-red-700 mt-auto">
    <div class="container mx-auto px-4">
        <div
            class="flex flex-col md:flex-row justify-between items-center gap-8"
        >
            <!-- Brand Section -->
            <div class="text-center md:text-left">
                <h3
                    class="text-2xl font-bold font-heading uppercase tracking-widest text-red-600"
                >
                    Red Demons
                </h3>
                <p class="text-gray-400 text-sm mt-2 max-w-xs">
                    Unleashing passion and power on the court since 2025.
                </p>
            </div>

            <!-- Social Links -->
            <div class="flex space-x-6">
                <a
                    href="#"
                    class="text-gray-400 hover:text-red-500 transition-transform hover:scale-110 duration-200"
                    aria-label="Instagram"
                >
                    <svg
                        class="w-8 h-8"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772 4.902 4.902 0 011.772-1.153c.636-.247 1.363-.416 2.427-.465C9.673 2.013 10.03 2 12.315 2zm-1.096 14.166c-2.477.106-4.632-1.585-5.188-4.017-.696-2.98 1.112-5.91 4.032-6.52 2.966-.62 5.86 1.25 6.43 4.22.484 2.508-1.053 4.888-3.52 5.76-.575.203-1.178.432-1.754.557zm14.672-9.613c0 .873-.708 1.58-1.58 1.58-.873 0-1.58-.708-1.58-1.58s.707-1.579 1.58-1.579c.872 0 1.58.707 1.58 1.58zM12.315 7.15c-2.721 0-4.927 2.206-4.927 4.925S9.593 17 12.315 17c2.72 0 4.927-2.205 4.927-4.925s-2.207-4.925-4.927-4.925z"
                            clip-rule="evenodd"></path>
                    </svg>
                </a>
                <a
                    href="#"
                    class="text-gray-400 hover:text-red-500 transition-transform hover:scale-110 duration-200"
                    aria-label="Twitter"
                >
                    <svg
                        class="w-8 h-8"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                    >
                        <path
                            d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"
                        ></path>
                    </svg>
                </a>
            </div>

            <!-- Contact Info -->
            <div class="text-center md:text-right">
                <p
                    class="text-lg font-bold uppercase tracking-wide mb-1 text-white"
                >
                    Contact Us
                </p>
                <a
                    href="mailto:info@reddemons.com"
                    class="text-red-500 hover:text-white transition-colors block text-base font-semibold"
                    >info@reddemons.com</a
                >
                <p class="text-gray-500 text-sm mt-1">+1 (555) 123-4567</p>
            </div>
        </div>

        <div
            class="border-t border-zinc-900 mt-10 pt-6 text-center text-xs text-zinc-600 font-mono"
        >
            &copy; {currentYear} RED DEMONS. ALL RIGHTS RESERVED.
        </div>
    </div>
</footer>
