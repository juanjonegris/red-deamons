---
import CartIcon from "./cart/CartIcon.astro";
---

<header
    class="bg-black border-b-4 border-red-700 sticky top-0 z-50 shadow-lg shadow-red-900/20"
>
    <div class="container mx-auto px-4 py-4 flex justify-between items-center">
        <!-- Logo / Icon Area -->
        <div class="flex items-center space-x-3 group cursor-pointer">
            <div
                class="w-28 h-28 bg-gradient-to-br from-red-600 to-red-800 rounded-full flex items-center justify-center text-white font-bold border-2 border-white/10 group-hover:scale-105 transition-transform duration-300"
            >
                <!-- Placeholder for Icon -->
                <img
                    src="/src/assets/logo.svg"
                    alt="Logo"
                    class="w-full h-full object-contain"
                />
            </div>
            <!-- <span
                class="text-2xl font-bold text-white uppercase tracking-wider font-heading italic group-hover:text-red-500 transition-colors"
                >Red Demons</span
            > -->
        </div>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex space-x-8">
            <a
                href="/"
                class="text-white hover:text-red-500 font-bold uppercase tracking-wide transition-colors relative group"
            >
                INICIO
                <span
                    class="absolute -bottom-1 left-0 w-0 h-0.5 bg-red-600 transition-all duration-300 group-hover:w-full"
                ></span>
            </a>
            <a
                href="/hincha"
                class="text-white hover:text-red-500 font-bold uppercase tracking-wide transition-colors relative group"
            >
                HINCHA
                <span
                    class="absolute -bottom-1 left-0 w-0 h-0.5 bg-red-600 transition-all duration-300 group-hover:w-full"
                ></span>
            </a>
            <a
                href="/planteles"
                class="text-white hover:text-red-500 font-bold uppercase tracking-wide transition-colors relative group"
            >
                PLANTELES
                <span
                    class="absolute -bottom-1 left-0 w-0 h-0.5 bg-red-600 transition-all duration-300 group-hover:w-full"
                ></span>
            </a>
            <a
                href="/juegos"
                class="text-white hover:text-red-500 font-bold uppercase tracking-wide transition-colors relative group"
            >
                JUEGOS
                <span
                    class="absolute -bottom-1 left-0 w-0 h-0.5 bg-red-600 transition-all duration-300 group-hover:w-full"
                ></span>
            </a>
            <a
                href="/tienda"
                class="text-white hover:text-red-500 font-bold uppercase tracking-wide transition-colors relative group"
            >
                TIENDA
                <span
                    class="absolute -bottom-1 left-0 w-0 h-0.5 bg-red-600 transition-all duration-300 group-hover:w-full"
                ></span>
            </a>
            <a
                href="/noticias"
                class="text-white hover:text-red-500 font-bold uppercase tracking-wide transition-colors relative group"
            >
                NOTICIAS
                <span
                    class="absolute -bottom-1 left-0 w-0 h-0.5 bg-red-600 transition-all duration-300 group-hover:w-full"
                ></span>
            </a>
            <a
                href="/contacto"
                class="text-white hover:text-red-500 font-bold uppercase tracking-wide transition-colors relative group"
            >
                Contacto
                <span
                    class="absolute -bottom-1 left-0 w-0 h-0.5 bg-red-600 transition-all duration-300 group-hover:w-full"
                ></span>
            </a>
        </nav>

        <!-- Cart Icon -->
        <div class="flex items-center space-x-4">
            <a href="/carrito" class="block">
                <div id="cart-icon-container">
                    <!-- Cart icon will be rendered client-side -->
                </div>
            </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
            id="mobile-menu-btn"
            class="md:hidden text-white hover:text-red-500 focus:outline-none transition-colors"
            aria-label="Toggle menu"
        >
            <svg
                class="w-8 h-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>

    <!-- Mobile Nav -->
    <div
        id="mobile-menu"
        class="hidden md:hidden bg-zinc-900 border-t border-zinc-800"
    >
        <nav class="flex flex-col p-4 space-y-4">
            <a
                href="/"
                class="text-white hover:text-red-500 font-bold uppercase block tracking-wide"
                >INICIO</a
            >
            <a
                href="/hincha"
                class="text-white hover:text-red-500 font-bold uppercase block tracking-wide"
                >HINCHA</a
            >
            <a
                href="#"
                class="text-white hover:text-red-500 font-bold uppercase block tracking-wide"
                >PLANTELES</a
            >
            <a
                href="#"
                class="text-white hover:text-red-500 font-bold uppercase block tracking-wide"
                >JUEGOS</a
            >
            <a
                href="#"
                class="text-white hover:text-red-500 font-bold uppercase block tracking-wide"
                >TIENDA</a
            >
            <a
                href="#"
                class="text-white hover:text-red-500 font-bold uppercase block tracking-wide"
                >NOTICIAS</a
            >
            <a
                href="#"
                class="text-white hover:text-red-500 font-bold uppercase block tracking-wide"
                >MÁS</a
            >
            
            <!-- Mobile Cart Link -->
            <div class="pt-4 border-t border-zinc-800">
                <a
                    href="/carrito"
                    class="flex items-center space-x-2 text-white hover:text-red-500 font-bold uppercase block tracking-wide"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"
                        ></path>
                    </svg>
                    <span>Carrito (<span id="mobile-cart-count">0</span>)</span>
                </a>
            </div>
        </nav>
    </div>
</header>

<script>
    function getLocalCartItemCount() {
        try {
            const cartData = localStorage.getItem('red-demons-cart');
            if (!cartData) return 0;
            const cart = JSON.parse(cartData);
            return cart.items.reduce((total, item) => total + item.quantity, 0);
        } catch (error) {
            return 0;
        }
    }

    function renderCartIcon() {
        const itemCount = getLocalCartItemCount();
        const container = document.getElementById('cart-icon-container');
        const mobileCount = document.getElementById('mobile-cart-count');
        
        if (container) {
            container.innerHTML = `
                <button
                    class="relative p-2 text-white hover:text-red-500 transition-colors"
                    aria-label="Carrito de compras"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"
                        ></path>
                    </svg>
                    
                    ${itemCount > 0 ? `
                        <span
                            class="absolute -top-1 -right-1 bg-red-600 text-white text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center"
                        >
                            ${itemCount > 99 ? '99+' : itemCount}
                        </span>
                    ` : ''}
                </button>
            `;
        }
        
        if (mobileCount) {
            mobileCount.textContent = itemCount;
        }
    }

    // Initial render
    document.addEventListener('DOMContentLoaded', renderCartIcon);
    
    // Update cart count when storage changes
    window.addEventListener('storage', renderCartIcon);
    
    // Custom event for cart updates
    window.addEventListener('cartUpdated', renderCartIcon);
</script>

<script>
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");

    if (btn && menu) {
        btn.addEventListener("click", () => {
            menu.classList.toggle("hidden");
        });
    }
</script>
